generator client {
  provider = "prisma-client-js"
}

// Prisma 7: url は prisma.config.cjs で指定（スキーマの url は非対応）
datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  createdAt DateTime @default(now())

  meals     MealLog[]
}

/// ユーザーごとの目標・パーソナル設定（複数ユーザー対応）
/// userId = 認証の sub または "default"（未ログイン時）
model UserConfig {
  userId       String   @id
  goals        Json?    // { calories, protein, fat, carbs }
  personal     Json?    // { heightCm, weightKg, age, sex?, activityLevel? }
  systemPrompt String?  // AI評価用システムプロンプト（未設定時はデフォルトを使用）
  updatedAt    DateTime @updatedAt
}

model MealLog {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  loggedAt     DateTime
  mealType     String
  source       String?   // asken / manual / import
  note         String?

  totalCal     Float?    // 任意：取り込み後に集計して埋める
  totalProtein Float?
  totalFat     Float?
  totalCarb    Float?

  items        MealItem[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, loggedAt])
}

model MealItem {
  id        String   @id @default(cuid())
  mealId    String
  meal      MealLog  @relation(fields: [mealId], references: [id], onDelete: Cascade)

  name      String
  amount    Float?
  unit      String?
  cal       Float?
  protein   Float?
  fat       Float?
  carb      Float?

  createdAt DateTime @default(now())

  @@index([mealId])
}

/// あすけん・Strong の日次データを統合して保存するテーブル
/// ownerId: 将来の複数ユーザー分離用。null = default ユーザー。既存コードは変更なし。
model DailyData {
  id        String   @id @default(cuid())
  date      String   @unique  // YYYY-MM-DD（複数ユーザー時は @@unique([ownerId, date]) に移行予定）
  ownerId   String?  // 拡張用。未使用時は null

  /// あすけんの食事アイテム (JSON配列)
  askenItems     Json?  // [{ mealType, name, amount, calories }]
  /// あすけんの栄養素データ (JSON: { 朝食: { エネルギー: "500kcal", ... }, ... })
  askenNutrients Json?  // Record<string, Record<string, string>>
  
  /// Strong 筋トレデータ (JSON)
  strongData     Json?  // { workouts: [...], totals: { ... } }
  
  /// 歩数 (あすけんヘルスケア連携)
  steps              Int?
  /// 運動消費カロリー (kcal)
  exerciseCalories   Float?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([ownerId])
}

/// AI 評価結果を保存するテーブル
/// ownerId: 将来の複数ユーザー分離用。null = default。既存コードは変更なし。
model AiEvaluation {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD（評価対象日）
  ownerId   String?  // 拡張用。未使用時は null
  type      String   // "daily" | "weekly"
  model     String   // 使用したモデル名
  prompt    String   // 送信したプロンプト
  response  String   // AIの回答テキスト
  trigger   String   // "manual" | "cron"（実行トリガー）
  createdAt DateTime @default(now())

  @@index([date])
  @@index([type, date])
  @@index([ownerId])
}

/// 同期ログ（最終同期時刻・結果を保持、常にid=1の1レコード）
/// ownerId: 将来の複数ユーザー分離用。null = default。既存コードは変更なし。
model SyncLog {
  id          Int      @id @default(1)
  ownerId     String?  // 拡張用。未使用時は null
  timestamp   DateTime @default(now())
  askenCount  Int      @default(0) @map("asken_count")
  strongCount Int      @default(0) @map("strong_count")
  dayCount    Int      @default(0) @map("day_count")
  errors      String?  // JSON文字列
}

/// ユーザーが利用するデータソース（あすけん・Strong・他アプリ）の登録用。
/// 現状は未使用。将来の他アプリ連携・複数ユーザー対応で使う。
model Integration {
  id         String   @id @default(cuid())
  userId     String
  sourceType String   // "asken" | "strong" | "manual" | 将来 "myfitnesspal" など
  config     Json?    // 認証情報は別途暗号化等を検討
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, sourceType])
  @@index([userId])
}

/// アプリ設定（目標・パーソナル）— 非推奨: ユーザー単位は UserConfig を使用
model AppConfig {
  id          Int   @id @default(1)
  goals       Json?
  personal    Json?
  updatedAt   DateTime @updatedAt
}
