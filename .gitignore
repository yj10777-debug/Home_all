# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Asken Scraping
secrets/
scripts/asken/dist/

# ルート直下の一時デバッグスクリプト
/_*.cjs

# デバッグ用の一時ビルドディレクトリ（削除待ちの残骸）
/.tmpbuild/
/.tb_*/
/.tb2_*/

# AI評価のエクスポートダンプ（個人の健康・食事データを含むためコミット禁止）
/ai_evals_output.json

# Claude Code のマシンローカル設定（個人の許可設定のため共有しない）
.claude/settings.local.json
