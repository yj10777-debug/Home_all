# Prisma / DB（必須: npm run db, マイグレーションで使用）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT 検証（API で Bearer トークン検証する場合）
# SUPABASE_JWT_SECRET=

# あすけん（同期スクリプト用）
# ASKEN_EMAIL=
# ASKEN_PASSWORD=

# Strong データパス（同期用）
# STRONG_DATA_PATH=

# Google Drive（Strong 連携）・Google Calendar（出社/在宅判定）
# カレンダー連携を使う場合は google-auth 実行時に Calendar スコープが含まれるため、
# 既存トークンがある場合は再認証（npx tsx scripts/google-auth.ts）で新しいトークンを取得してください。
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_STRONG_FOLDER_ID=
# GOOGLE_CALENDAR_ID=primary

# 定期同期
# CRON_SCHEDULE=
# CRON_SECRET=
# CRON_RUN_ON_START=

# Gemini AI
# GEMINI_API_KEY=
# GEMINI_MODEL=
